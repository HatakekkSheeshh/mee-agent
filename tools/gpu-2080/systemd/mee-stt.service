# Mee STT + diarization server — systemd unit for nhihb-gpu-2080.
# Install (on the 2080 box, replace YOUR_USER + HF_TOKEN + SERVER_TOKEN):
#   sudo cp mee-stt.service /etc/systemd/system/
#   sudo nano /etc/systemd/system/mee-stt.service      # fill the placeholders
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now mee-stt
#   journalctl -u mee-stt -f                            # tail logs
[Unit]
Description=Mee STT + diarization (faster-whisper + PhoWhisper + pyannote)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/stt-server
Environment="HF_TOKEN=hf_xxxxxxxxxxxxx"
Environment="SERVER_TOKEN=REPLACE_WITH_RANDOM_HEX"
Environment="PORT=9100"
Environment="STT_BACKENDS=faster_whisper,phowhisper"
Environment="PATH=/home/YOUR_USER/stt-server/.venv/bin"
ExecStart=/home/YOUR_USER/stt-server/.venv/bin/python /home/YOUR_USER/stt-server/mee_stt_server.py
Restart=on-failure
RestartSec=10
# Models can take ~60s to load on first start (pyannote + first STT backend).
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
