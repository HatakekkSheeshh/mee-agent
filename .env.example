# ╔════════════════════════════════════════════════════════════════╗
# ║  Mee Meeting Agent — .env.example                              ║
# ║  Copy to .env and fill real values. .env is gitignored.        ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── Whisper (STT) — VNGCloud MaaS ─────────────────────────
# URL pattern: /maas/<user-id>/<provider>/<model>/v1/<endpoint>
WHISPER_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/whisper-large-v3
WHISPER_API_KEY=your-vng-api-key-here
WHISPER_MODEL=openai/whisper-large-v3

# ─── LLM (chat + MoM generation) ───────────────────────────
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/gpt-oss-120b/v1
LLM_API_KEY=your-vng-api-key-here
LLM_MODEL=openai/gpt-oss-120b

# ─── Postgres (docker-compose) ─────────────────────────────
# docker-compose.yml reads these to start mee-postgres container.
POSTGRES_USER=mee
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_DB=mee

# ─── Database URLs for app + Alembic ───────────────────────
# Format: postgresql+<driver>://USER:PASS@HOST:PORT/DB
# Async driver (runtime app) — must match POSTGRES_* above
DATABASE_URL=postgresql+asyncpg://mee:change_me_to_strong_password@localhost:5435/mee
# Sync driver (Alembic migrations) — same DB, different driver
DATABASE_URL_SYNC=postgresql+psycopg2://mee:change_me_to_strong_password@localhost:5435/mee
