# ╔════════════════════════════════════════════════════════════════╗
# ║  Mee Meeting Agent — .env.example                              ║
# ║  Copy to .env and fill real values. .env is gitignored.        ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── Whisper (STT) — VNGCloud MaaS ─────────────────────────
# URL pattern: /maas/<user-id>/<provider>/<model>  (no /v1 suffix for Whisper)
WHISPER_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/whisper-large-v3
WHISPER_API_KEY=your-vng-api-key-here
WHISPER_MODEL=openai/whisper-large-v3

# ─── LLM (chat + MoM generation) ───────────────────────────
# Standard OpenAI-compatible endpoint. Swap to any provider (Anthropic,
# OpenAI, Together, etc.) by changing the 3 vars below — no code change.
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/gpt-oss-120b/v1
LLM_API_KEY=your-vng-api-key-here
LLM_MODEL=openai/gpt-oss-120b

# ─── Database URL ──────────────────────────────────────────
# Required. Code accepts plain `postgresql://` and auto-prepends the right
# driver (asyncpg for runtime, psycopg2 for Alembic). Pre-fixed URLs like
# `postgresql+asyncpg://...` also work.
#
# Special chars in password: $ % @ etc. are preserved as-is (dotenv loads
# with interpolate=False) — no need to URL-encode them.
#
# Option A — Remote managed Postgres (recommended; VDB / Neon / Supabase / RDS)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Optional explicit sync URL for Alembic (defaults to DATABASE_URL if unset):
# DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Option B — Local Postgres via docker-compose (see docker-compose.yml)
# Uncomment the 3 POSTGRES_* lines, run: docker compose --profile local up -d
# Then set DATABASE_URL to localhost:5435 below.
# POSTGRES_USER=mee
# POSTGRES_PASSWORD=mee_dev_password
# POSTGRES_DB=mee
# DATABASE_URL=postgresql://mee:mee_dev_password@localhost:5435/mee
