# ╔════════════════════════════════════════════════════════════════╗
# ║  Mee Meeting Agent — .env.example                              ║
# ║  Copy to .env and fill real values. .env is gitignored.        ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── Whisper (STT) ──────────────────────────────────────────
# Option A — VNGCloud MaaS Whisper (managed)
# URL pattern: /maas/<user-id>/<provider>/<model>  (no /v1 suffix)
WHISPER_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/whisper-large-v3
WHISPER_API_KEY=your-vng-api-key-here
WHISPER_MODEL=openai/whisper-large-v3

# Option B — Self-hosted PhoWhisper-large + pyannote
# WHISPER_BASE_URL=http://<IP>:9100/v1
# WHISPER_API_KEY=not-used-but-keep-something
# WHISPER_MODEL=phowhisper

# ─── LLM (chat + MoM generation + transcript cleaning) ────
# Legacy default — used when a profile-specific var below is unset, AND as
# the "Inherit default" choice in the model picker (recording.llm_model = NULL).
LLM_BASE_URL=http://<your-llm-host>:8000/v1
LLM_API_KEY="EMPTY"
LLM_MODEL=Qwen/Qwen3-8B

# ─── Multi-model profiles (migration 0014 + model_registry.py) ───
# User can pick STT/LLM per recording or per meeting in the UI detail panel.
# Each logical ID resolves to its profile-specific env vars below; missing
# vars fall back to the legacy WHISPER_*/LLM_* values above.
#
# STT profiles ─────────────────────────────────────────────
# "whisper" (default) — uses WHISPER_* above (MaaS Whisper large-v3).
# "phowhisper" — self-hosted PhoWhisper + pyannote on L40.
PHOWHISPER_BASE_URL=http://<your-phowhisper-host>:9100
PHOWHISPER_API_KEY=EMPTY
PHOWHISPER_MODEL=phowhisper
#
# LLM profiles ─────────────────────────────────────────────
# "gemma" (default) — balanced, 128K context, recommended for most meetings.
GEMMA_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/google/gemma-4-31b-it/v1
GEMMA_API_KEY=your-vng-api-key-here
GEMMA_MODEL=google/gemma-4-31b-it
# "qwen" — stronger reasoning, 16K context, 50 req/day MaaS quota.
QWEN_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/qwen/qwen3-5-27b/v1
QWEN_API_KEY=your-vng-api-key-here
QWEN_MODEL=qwen/qwen3-5-27b
# "gpt-oss" — most capable, slower, for high-accuracy meetings.
GPT_OSS_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/gpt-oss-120b/v1
GPT_OSS_API_KEY=your-vng-api-key-here
GPT_OSS_MODEL=openai/gpt-oss-120b

# ─── Embedding (bge-m3 for memory retrieval) ───────────────
EMBEDDING_BASE_URL=https://maas-embedding-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/bge-m3/v1
EMBEDDING_API_KEY=your-vng-api-key-here
EMBEDDING_MODEL=BAAI/bge-m3

# ─── Celery + RabbitMQ (background MoM gen) ──────────────────
# Defaults match docker-compose.yml RabbitMQ service. Override if running
# RabbitMQ elsewhere (eg. CloudAMQP for production).
# Start: docker compose up -d rabbitmq
# Management UI: http://localhost:15672  (user / pass below)
RABBITMQ_USER=mee
RABBITMQ_PASSWORD=mee_dev_password
# Full broker URL — uncomment to override the auto-built one above
# CELERY_BROKER_URL=amqp://mee:mee_dev_password@localhost:5672//
# Result backend: rpc:// uses RabbitMQ's RPC reply queues (no extra service).
# Switch to redis://… if you need long-lived result caching.
# CELERY_RESULT_BACKEND=rpc://
# Worker tuning — defaults are dev-friendly (low overhead).
#   pool=solo: single-process, fastest startup, one task at a time
#   pool=prefork: multi-process, set CELERY_CONCURRENCY for parallelism (prod)
# CELERY_POOL=solo
# CELERY_CONCURRENCY=2
# CELERY_LOGLEVEL=warning

# ─── Remote pyannote server (optional GPU offload) ─────────────
# When set, diarization HTTP-calls a remote pyannote server (eg. a
# Kaggle T4 notebook, Modal Labs function, or self-hosted vLLM box)
# instead of running pyannote on local CPU. 10-50× faster.
#
# Setup: see tools/kaggle/pyannote_server.py for the Kaggle notebook
# script + cloudflared tunnel instructions. The token must match
# SERVER_TOKEN set in the Kaggle notebook's Secrets.
#
# Falls back to local CPU pyannote automatically when the remote is
# unreachable / 5xx / token mismatch — safe to leave PYANNOTE_REMOTE_URL
# set even when the Kaggle kernel is offline.
# PYANNOTE_REMOTE_URL=https://abc123.trycloudflare.com
# PYANNOTE_REMOTE_TOKEN=your-random-token-matching-kaggle-SERVER_TOKEN

# ─── Auth (mock O365 dev → real O365 when IT grants) ───────────
# AUTH_PROVIDER selects the implementation at startup:
#   mock       — fake MS login UI for dev/demo, accepts any email
#   microsoft  — real O365 via MSAL; needs MS_* vars below
AUTH_PROVIDER=mock
# HMAC secret for the session cookie. MUST override in production —
# defaults to an unsafe placeholder that any reader of source code can forge.
# Generate: openssl rand -hex 32
SESSION_SECRET=
# True in prod (HTTPS), false in dev (http://localhost won't accept secure cookies).
SESSION_COOKIE_SECURE=false
# Skip the voice-enrollment gate after login. Set true on deploys that
# don't ship the local pyannote/torch embedding stack (e.g. AgentBase
# single-port image) so users land on /app instead of a failing enroll.
VOICE_ENROLL_OPTIONAL=false
# Real O365 (uncomment + fill when AUTH_PROVIDER=microsoft).
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=common
# Pin the OAuth redirect to the URL registered in Azure. REQUIRED in dev:
# Vite (:8001) proxies /auth → backend (:8002), so the redirect_uri can't be
# derived from the request — it must match the registered :8001 URL exactly.
# MS_REDIRECT_URI=http://localhost:8001/auth/callback
# AES-256-GCM key for encrypting the stored Microsoft refresh token (MSAL
# cache) at rest in users.refresh_token. Any string works (SHA-256-derived to
# 32 bytes); falls back to SESSION_SECRET if unset. Generate: openssl rand -hex 32
TOKEN_ENC_KEY=

# ─── Database (Postgres + pgvector REQUIRED) ──────────────
# Option A — Remote managed Postgres (recommended; VDB / Neon / Supabase / RDS)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Optional explicit sync URL for Alembic (defaults to DATABASE_URL if unset):
# DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Option B — Local Postgres via docker-compose (uses pgvector image)
# POSTGRES_USER=mee
# POSTGRES_PASSWORD=mee_dev_password
# POSTGRES_DB=mee
# DATABASE_URL=postgresql://mee:mee_dev_password@localhost:5435/mee

# ─── pm-agent (A2A — Redmine project management over Agent-to-Agent) ───
# The meeting chat drives pm-agent's redmine_query / redmine_mutate skills
# via A2A v0.3 JSON-RPC (message/send). Auth is a per-user identity token sent
# as `Authorization: Bearer <token>` (agentbase delegates the Redmine key to
# the session after a one-time browser auth). URL MUST end with `/a2a/`.
PM_AGENT_URL=https://endpoint-e05e38a1-6070-4f9d-8ab2-80ea965ec2f6.agentbase-runtime.aiplatform.vngcloud.vn/a2a/
TOKEN_AUTHEN_PM_AGENT=your-pm-agent-identity-token-here
# How chat authenticates to pm-agent:
#   jwt (default) — forward the user's MS Graph access token (real O365 login)
#   oid           — forward the user's raw OID to pm-agent's direct-oid test
#                   port (temporary; mock users fall back to the OID above)
PM_AGENT_AUTH_MODE=jwt
# Optional: request timeout in seconds (default 60)
# PM_AGENT_TIMEOUT=60


# Tracing — OpenTelemetry → Jaeger + Langfuse (all optional; no-op unless enabled).
# One OpenInference instrumentation, fanned out to both backends.
OTEL_ENABLED=false                                   # true → export spans to Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318    # Jaeger OTLP/HTTP receiver
OTEL_SERVICE_NAME=mee-meeting-agent
LANGFUSE_ENABLED=false                               # true → export LLM traces to Langfuse
LANGFUSE_HOST=http://localhost:3000                  # your Langfuse instance
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here    # Langfuse → project Settings → API Keys
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
