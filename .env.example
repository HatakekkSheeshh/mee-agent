# ╔════════════════════════════════════════════════════════════════╗
# ║  Mee Meeting Agent — .env.example                              ║
# ║  Copy to .env and fill real values. .env is gitignored.        ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── Whisper (STT) ──────────────────────────────────────────
# Option A — VNGCloud MaaS Whisper (managed)
# URL pattern: /maas/<user-id>/<provider>/<model>  (no /v1 suffix)
WHISPER_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/whisper-large-v3
WHISPER_API_KEY=your-vng-api-key-here
WHISPER_MODEL=openai/whisper-large-v3

# Option B — Self-hosted PhoWhisper-large + pyannote
# WHISPER_BASE_URL=http://<IP>:9100/v1
# WHISPER_API_KEY=not-used-but-keep-something
# WHISPER_MODEL=phowhisper

# ─── LLM (chat + MoM generation + transcript cleaning) ────
# Legacy default — used when a profile-specific var below is unset, AND as
# the "Inherit default" choice in the model picker (recording.llm_model = NULL).
LLM_BASE_URL=http://<your-llm-host>:8000/v1
LLM_API_KEY="EMPTY"
LLM_MODEL=Qwen/Qwen3-8B

# ─── Multi-model profiles (migration 0014 + model_registry.py) ───
# User can pick STT/LLM per recording or per meeting in the UI detail panel.
# Each logical ID resolves to its profile-specific env vars below; missing
# vars fall back to the legacy WHISPER_*/LLM_* values above.
#
# STT profiles ─────────────────────────────────────────────
# "whisper" (default) — uses WHISPER_* above (MaaS Whisper large-v3).
# "phowhisper" — self-hosted PhoWhisper + pyannote on L40.
PHOWHISPER_BASE_URL=http://<your-phowhisper-host>:9100
PHOWHISPER_API_KEY=EMPTY
PHOWHISPER_MODEL=phowhisper
#
# LLM profiles ─────────────────────────────────────────────
# "gemma" (default) — balanced, 128K context, recommended for most meetings.
GEMMA_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/google/gemma-4-31b-it/v1
GEMMA_API_KEY=your-vng-api-key-here
GEMMA_MODEL=google/gemma-4-31b-it
# "qwen" — stronger reasoning, 16K context, 50 req/day MaaS quota.
QWEN_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/qwen/qwen3-5-27b/v1
QWEN_API_KEY=your-vng-api-key-here
QWEN_MODEL=qwen/qwen3-5-27b
# "gpt-oss" — most capable, slower, for high-accuracy meetings.
GPT_OSS_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/openai/gpt-oss-120b/v1
GPT_OSS_API_KEY=your-vng-api-key-here
GPT_OSS_MODEL=openai/gpt-oss-120b

# ─── Embedding (bge-m3 for memory retrieval) ───────────────
EMBEDDING_BASE_URL=https://maas-embedding-aiplatform-hcm.api.vngcloud.vn/maas/user-XXXXX/bge-m3/v1
EMBEDDING_API_KEY=your-vng-api-key-here
EMBEDDING_MODEL=BAAI/bge-m3

# ─── Database (Postgres + pgvector REQUIRED) ──────────────
# Option A — Remote managed Postgres (recommended; VDB / Neon / Supabase / RDS)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Optional explicit sync URL for Alembic (defaults to DATABASE_URL if unset):
# DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Option B — Local Postgres via docker-compose (uses pgvector image)
# POSTGRES_USER=mee
# POSTGRES_PASSWORD=mee_dev_password
# POSTGRES_DB=mee
# DATABASE_URL=postgresql://mee:mee_dev_password@localhost:5435/mee

# ─── pm-agent (A2A — Redmine project management over Agent-to-Agent) ───
# The meeting chat drives pm-agent's redmine_query / redmine_mutate skills
# via A2A v0.3 JSON-RPC (message/send). Auth is a per-user identity token sent
# as `Authorization: Bearer <token>` (agentbase delegates the Redmine key to
# the session after a one-time browser auth). URL MUST end with `/a2a/`.
PM_AGENT_URL=https://endpoint-e05e38a1-6070-4f9d-8ab2-80ea965ec2f6.agentbase-runtime.aiplatform.vngcloud.vn/a2a/
TOKEN_AUTHEN_PM_AGENT=your-pm-agent-identity-token-here
# Optional: request timeout in seconds (default 60)
# PM_AGENT_TIMEOUT=60


# Tracing
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here